# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git — it contains secrets

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-64-char-random-hex

# ── Notion (Host / Platform key — reads the Users table) ─────────────────────
# Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_...
NOTION_USERS_DB_ID=...   # The Notion database ID of your Users table

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini (free at aistudio.google.com)
GEMINI_API_KEY=AIza...
