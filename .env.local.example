# Copy this file to .env.local and fill in your values 
# NEVER commit .env.local to git — it contains secrets
#
# Only AUTH_SECRET is required for the app to boot. Login additionally needs the
# Notion platform key + Users DB. Everything else is per-feature: if unset, that
# feature returns "not configured" instead of crashing the app.

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# Signs login JWTs and form tokens. Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-64-char-random-hex

# ── Notion (Host / Platform key — reads the Users table) ──────────────────────
# Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_...
NOTION_USERS_DB_ID=...   # Notion database ID of your Users table (REQUIRED for login)

# ── Shared company Notion databases (per-feature) ─────────────────────────────
# Each backs a feature module (admin clients/overview, portfolio, insurance,
# cashflow, assets, tasks, forms library, AI-usage tracking).
COMPANY_CLIENTS_DB_ID=...
COMPANY_PORTFOLIO_DB_ID=...
COMPANY_INSURANCE_DB_ID=...
COMPANY_CASHFLOW_DB_ID=...
COMPANY_ASSETS_DB_ID=...
COMPANY_TASKS_DB_ID=...
COMPANY_FORMS_DB_ID=...
COMPANY_AI_USAGE_DB_ID=...

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini (free at aistudio.google.com)
GEMINI_API_KEY=AIza...

# ── Google OAuth (Gmail, Drive, Calendar) ─────────────────────────────────────
# Create OAuth client at: https://console.cloud.google.com/apis/credentials
# Register the redirect URI(s) below in the client's "Authorized redirect URIs".
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/callback
# Optional. Defaults to {GOOGLE_REDIRECT_URI origin}/api/calendar/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=

# ── Microsoft OAuth (Outlook mail / calendar) ─────────────────────────────────
# Register an app at: https://portal.azure.com / https://entra.microsoft.com/ → App registrations
MS_CLIENT_ID=...
MS_CLIENT_SECRET=...
MS_REDIRECT_URI=http://localhost:3000/api/email/outlook/callback

# ── Misc ──────────────────────────────────────────────────────────────────────
# Base URL used to build shareable cashflow/networth links.
# Falls back to VERCEL_PROJECT_PRODUCTION_URL (auto-set on Vercel) then relative.
NEXT_PUBLIC_BASE_URL=APP URL (e.g. http://localhost:3000 or https://app.domain.com)
# Bearer secret protecting the scheduled /api/cron/market-digest endpoint.
CRON_SECRET=...
